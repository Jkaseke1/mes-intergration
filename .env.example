# Sage Pastel 200 Evolution connection
SAGE_DATABASE=your_sage_db_name
SAGE_USER=sa
SAGE_PASSWORD=your_password

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key

# Bridge worker mode
DRY_RUN=false

# Sage transaction codes (must exist in TrCodes table where iModule = 11)
# Defaults discovered from the user's Sage dataset:
# GRV  = Goods Received Voucher (debit inventory, credit GRN accrual)
# MFDR = Manufacturing Draw (raw material issue to WIP)
# MFMF = Manufacturing Manufacture (FG/WIP receipt)
# WHT  = Warehouse Transfer (dispatch/transfer, GL net zero)
# ADJ  = Adjustments (recon variances)
SAGE_TX_CODE_GRN=GRV
SAGE_TX_CODE_ISSUE=MFDR
SAGE_TX_CODE_PRODUCTION=MFMF
SAGE_TX_CODE_DISPATCH=WHT
SAGE_TX_CODE_RECON=ADJ
SAGE_TX_CODE_MACROPACK=MFMF

# Sage GL account codes (Master_Sub_Account format, e.g., "7000-GRA-7025")
# Leave these empty to use the default TrCodes GL accounts. Only set them to override.
# SAGE_GL_ACCOUNT_GRN=
# SAGE_GL_ACCOUNT_WIP=
# SAGE_GL_ACCOUNT_COGS=
# SAGE_GL_ACCOUNT_RECON=2200-DEB-1120

# Username to stamp on posted Sage transactions
SAGE_POST_USERNAME=HYPER-MES
